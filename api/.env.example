# Haven API - Local Development
# Copy this to .env and fill in the values

DATABASE_URL=postgresql+asyncpg://haven:haven@localhost:5432/haven_platform

KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=haven

K8S_INCLUSTER=false
# K8S_KUBECONFIG=/Users/yourname/.kube/config

HARBOR_URL=http://localhost:5000
HARBOR_PROJECT=haven

BUILD_NAMESPACE=haven-builds
LB_IP=127.0.0.1

DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production
API_PREFIX=/api/v1
