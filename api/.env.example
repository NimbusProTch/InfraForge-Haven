# Haven Platform API — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# Database (PostgreSQL via CNPG or local)
DATABASE_URL=postgresql+asyncpg://haven:haven@localhost:5432/haven_platform

# Keycloak (OIDC auth)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=haven
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=          # REQUIRED
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli

# Kubernetes
K8S_INCLUSTER=false
K8S_KUBECONFIG=                   # Path to kubeconfig (local dev only)

# Harbor (container registry)
HARBOR_URL=http://harbor.example.com
HARBOR_PROJECT=haven
HARBOR_ADMIN_PASSWORD=            # REQUIRED
HARBOR_REGISTRY_SECRET=harbor-registry-secret

# Build pipeline
BUILD_NAMESPACE=haven-builds
LB_IP=127.0.0.1                  # Hetzner LB IP for sslip.io hostnames

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/github/callback

# Webhook
WEBHOOK_SECRET=

# GitOps (set GITOPS_REPO_URL to enable GitOps mode)
GITOPS_REPO_URL=                  # e.g. http://localhost:3030/haven/haven-gitops.git
GITOPS_BRANCH=main
GITOPS_CLONE_DIR=/tmp/haven-gitops
GITOPS_DEPLOY_KEY_PATH=
GITOPS_GITHUB_TOKEN=

# ArgoCD ApplicationSet uses this URL (cluster-internal Gitea)
GITOPS_ARGOCD_REPO_URL=           # e.g. http://gitea-http.gitea-system.svc.cluster.local:3000/haven/haven-gitops.git

# Helm chart repo for ArgoCD multi-source
CHART_REPO_URL=                   # Default: https://github.com/NimbusProTch/InfraForge-Haven.git

# ArgoCD API
ARGOCD_URL=http://localhost:8443
ARGOCD_AUTH_TOKEN=

# Redis
REDIS_URL=redis://localhost:6379/0

# Gitea
GITEA_URL=                        # e.g. http://localhost:3030
GITEA_ADMIN_TOKEN=
GITEA_ORG=haven
GITEA_GITOPS_REPO=haven-gitops
GITEA_GITOPS_BRANCH=main

# Percona Everest
EVEREST_URL=http://localhost:8888
EVEREST_ADMIN_USER=admin
EVEREST_ADMIN_PASSWORD=           # REQUIRED
EVEREST_NAMESPACE=everest

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# HashiCorp Vault (sensitive env var storage)
VAULT_URL=                        # e.g. http://vault.vault-system.svc:8200 (empty = K8s Secret fallback)
VAULT_TOKEN=                      # Vault API token with haven-api-writer policy

# App
DEBUG=true
SECRET_KEY=                       # REQUIRED — generate: python -c "import secrets; print(secrets.token_hex(32))"
API_PREFIX=/api/v1
