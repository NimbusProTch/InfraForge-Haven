# Haven App — GitOps values
# Generated by Haven Platform API
# Tenant: {{ tenant_slug }}  App: {{ app_slug }}
image:
  repository: "{{ image_repository | default('') }}"
  tag: "{{ image_tag | default('latest') }}"
  pullPolicy: Always

appSlug: "{{ app_slug }}"
tenantSlug: "{{ tenant_slug }}"
port: {{ port | default(8000) }}
replicas: {{ replicas | default(1) }}

env:
{% if env_vars %}
{% for key, value in env_vars.items() %}
  {{ key }}: "{{ value }}"
{% endfor %}
{% else %}
  {}
{% endif %}

resources:
  requests:
    cpu: "{{ cpu_request | default('50m') }}"
    memory: "{{ memory_request | default('64Mi') }}"
  limits:
    cpu: "{{ cpu_limit | default('500m') }}"
    memory: "{{ memory_limit | default('512Mi') }}"

httproute:
  enabled: true
  gateway:
    name: haven-gateway
    namespace: haven-gateway
  hostname: ""

autoscaling:
  enabled: true
  minReplicas: 1
  maxReplicas: 5
  targetCPUUtilizationPercentage: 70

tolerations:
  - operator: "Exists"
