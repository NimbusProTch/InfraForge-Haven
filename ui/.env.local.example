# Haven UI - Local Development
# Copy this to .env.local and fill in the values

NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=dev-nextauth-secret-change-in-production

KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=haven
KEYCLOAK_CLIENT_ID=haven-ui
KEYCLOAK_CLIENT_SECRET=haven-ui-secret

NEXT_PUBLIC_API_URL=http://localhost:8001

# GitHub OAuth for NextAuth sign-in (optional)
# Callback URL: http://localhost:3001/api/auth/callback/github
# GITHUB_ID=your_client_id
# GITHUB_SECRET=your_client_secret
#
# NOTE: The "Connect GitHub" popup flow uses api/.env (GITHUB_CLIENT_ID/SECRET)
# Callback URL for that app: http://localhost:3001/github/callback
