{
  "realm": "haven",
  "displayName": "Haven Platform",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 28800,
  "ssoSessionMaxLifespan": 28800,
  "offlineSessionMaxLifespan": 604800,
  "offlineSessionIdleTimeout": 172800,
  "accessTokenLifespanForImplicitFlow": 3600,
  "clients": [
    {
      "clientId": "haven-ui",
      "name": "Haven UI",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3001/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3001",
        "http://localhost:3000"
      ],
      "protocol": "openid-connect",
      "secret": "${HAVEN_UI_CLIENT_SECRET}"
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "platform-admin",
        "description": "Haven SRE / operator role — grants access to cross-tenant admin endpoints (audit search, tenant enumeration, platform-wide ops). Sprint H2 P8.",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@haven.dev",
      "firstName": "Haven",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "${HAVEN_REALM_ADMIN_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-haven", "platform-admin"]
    }
  ]
}
